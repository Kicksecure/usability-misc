#!/bin/bash

#set -x
set -o errexit
set -o nounset
set -o errtrace
set -o pipefail

true "$0: START"

MYDIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd )"
cd -- "$MYDIR"
cd -- ..
cd -- ..
cd -- ..

## For future use in case of issues.
## Building dist-installer-cli is not crucial and a workaround to skip it might unbreak the build process.
## https://forums.whonix.org/t/derivative-maker-missing-usr-libexec-helper-scripts-get-colors-sh/20142
if [ "${dist_build_skip_installer_dist_standalone:-}" = "true" ]; then
  printf '%s\n' "$0: INFO: Skipping to build dist-installer-cli because dist_build_skip_installer_dist_standalone=true, ok."
  exit 0
fi

command -v git >/dev/null || exit 1

toplevel="$(git rev-parse --show-toplevel)"
target="${toplevel}/usr/share/usability-misc/dist-installer-cli-standalone"
template="${toplevel}/usr/bin/dist-installer-cli"
base_name_target="${target##*/}"

## debian/control 'Builds-Depends: helper-scripts' is not easily possible,
## because then the build chroot would also need helper-scripts being installed.
## Use system-installed helper-scripts. Operator is expected to have helper-scripts
## installed when running this build script.
helper_path="/usr/libexec/helper-scripts/"

if ! test -d "$helper_path" ; then
  printf '%s\n' "$0: ERROR: directory helper_path '$helper_path' does not exist!" >&2
  exit 1
fi

## Recursively inline every 'source ...helper-scripts/<name>' line so
## the resulting standalone has no source lines pointing at files
## that the standalone's runtime environment will not have.
##
## Two source-line forms are handled:
##   source /usr/libexec/helper-scripts/<name>
##   source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/<name>
## helper-scripts uses the second form for its own internal sources
## (so a non-installed dev checkout can override the path), so a
## non-recursive single-pass inliner would leave nested source lines
## pointing at /usr/libexec/helper-scripts in the produced standalone.
python3 - "$template" "$target" "$helper_path" "${0##*/}" <<'PY'
import re, sys, os

template, target, helper_path, origin = sys.argv[1:5]

source_pat = re.compile(
    r'^[ \t]*source[ \t]+'
    r'(?:"\$\{HELPER_SCRIPTS_PATH:-\}")?'
    r'/usr/libexec/helper-scripts/(\S+)\s*$'
)

def expand(text, depth=0):
    if depth > 16:
        sys.stderr.write(f"{origin}: error: source recursion too deep ({depth})\n")
        sys.exit(1)
    out = []
    for line in text.splitlines():
        m = source_pat.match(line)
        if not m:
            out.append(line)
            continue
        inner_path = os.path.join(helper_path, m.group(1))
        if not os.path.isfile(inner_path):
            sys.stderr.write(f"{origin}: error: sourced file does not exist: {inner_path}\n")
            sys.exit(1)
        with open(inner_path) as f:
            inner_text = f.read()
        out.append(f"##### BEGIN pasted by {origin} from file {inner_path}")
        out.append(expand(inner_text, depth + 1))
        out.append(f"##### END pasted by {origin} from file {inner_path}")
    return "\n".join(out)

with open(template) as f:
    content = f.read()
expanded = expand(content)
if not expanded.endswith("\n"):
    expanded += "\n"
with open(target, "w") as f:
    f.write(expanded)
PY

## Defense-in-depth: strip any remaining source-helper-scripts lines
## (matches both plain and ${HELPER_SCRIPTS_PATH:-}-prefixed forms).
## In a healthy build the recursive Python inliner above leaves none,
## but if a future helper-script gains a source line that does not
## match the inliner's regex, the standalone must not ship a source
## statement that will fail at runtime - delete it.
sed -i \
  -e '\,^[[:space:]]*source[[:space:]]\+/usr/libexec/helper-scripts/,d' \
  -e '\,^[[:space:]]*source[[:space:]]\+"\${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/,d' \
  -e "6i\\
##########################\\
## NOTE:\\
## AUTOGENERATED CODE!\\
## DO NOT MODIFY THIS '${base_name_target}' FILE!\\
## INSTEAD MODIFY ../../bin/dist-installer-cli and the functions sourced!\\
##########################\\
" \
  -- \
  "${target}"

printf '%s\n' "$0: INFO: BUILD: SUCCESS"
printf '%s\n' "$0: INFO: Running shellcheck..."

shellcheck "${target}"

printf '%s\n' "$0: INFO: shellcheck: SUCCESS"
printf '%s\n' "$0: INFO: END: OK"
